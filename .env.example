# LLM Provider: "openrouter" (default, free models) | "anthropic" (paid) | "gemini" (Google)
LLM_PROVIDER=openrouter

# OpenRouter (free tier — Llama, Qwen, Gemini cascade)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Anthropic (paid — Claude Sonnet 4)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Supabase (economic calendar — 19K+ events from ForexFactory)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Data enrichment APIs (all optional — graceful degradation)
FINNHUB_API_KEY=your-finnhub-key
FRED_API_KEY=your-fred-key
FMP_API_KEY=your-fmp-key
COINGECKO_API_KEY=your-coingecko-demo-key
MARKETAUX_API_KEY=your-marketaux-key   # Historical news backfill — marketaux.com free tier: 100 req/day (2 req/date)

# Google Gemini (Flash 2.5 / Pro 2.5 / 3.1 Pro)
GEMINI_API_KEY=your-gemini-api-key-here

# TTS Provider: "edge" (default, free) | "fish" (Fish Audio S2-Pro, ~$0.15/ep)
TTS_PROVIDER=edge

# Fish Audio (clone vocal, ~$3/mois)
FISH_API_KEY=your-fish-api-key-here
FISH_VOICE_ID=your-voice-clone-id

# ElevenLabs (legacy)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# YouTube OAuth (Phase 1C — upload-as-draft)
# Setup steps :
# 1. Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
#    - Type: Desktop application
#    - Add http://localhost:53682 to authorized redirect URIs
# 2. Enable YouTube Data API v3 for the project
# 3. Run `npm run publish -- --auth` once to obtain the refresh token (browser flow)
# 4. Token persists in YOUTUBE_REFRESH_TOKEN below
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
YOUTUBE_REFRESH_TOKEN=
# Default privacy for uploads (private | unlisted | public). Recommended: private (review in Studio first).
YOUTUBE_DEFAULT_PRIVACY=private
# If set, every upload is auto-added to this playlist (use scripts/setup-playlist.ts to create one)
YOUTUBE_PLAYLIST_ID=
# If set (0-23), schedule public release at next occurrence of that hour Paris time.
# Forces privacy=private. Auto-handles CEST/CET DST. 7 = 7am, optimal for morning market recap.
YOUTUBE_PUBLISH_HOUR_CET=7
