# LLM Provider: "openrouter" (default, free models) or "anthropic" (paid, better quality)
LLM_PROVIDER=openrouter

# OpenRouter (free tier — Llama, Qwen, Gemini cascade)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Anthropic (paid — Claude Sonnet 4)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Supabase (economic calendar — 19K+ events from ForexFactory)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Data enrichment APIs (all optional — graceful degradation)
FINNHUB_API_KEY=your-finnhub-key
FRED_API_KEY=your-fred-key
FMP_API_KEY=your-fmp-key
COINGECKO_API_KEY=your-coingecko-demo-key
MARKETAUX_API_KEY=your-marketaux-key   # Historical news backfill — marketaux.com free tier: 100 req/day (2 req/date)

# ElevenLabs (for TTS — Phase 3)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
