{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "lastUpdated": "2026-05-06",
  "doc": "Règles regex de phonétisation pour TTS Fish Audio. Catégorisées par usage. Les phonétiques par ticker/asset (Bitcoin, S&P 500, etc.) restent dans data/company-profiles.json — ce fichier ne contient QUE les règles génériques (anglicismes, sigles, banques centrales, fish bugs). L'ordre est : fish_bugs → geography → companies_named → anglicisms → suffixes → indices → acronyms → central_banks → linguistic.",
  "categories": [
    {
      "id": "fish_bugs",
      "description": "Bugs Fish Audio — mots que Fish prononce mal en raw. Phonétiser pour forcer.",
      "rules": [
        { "pattern": "\\bgrimpe\\b", "flags": "gi", "replacement": "grimp", "comment": "Fish lit le 'e' final" },
        { "pattern": "(?<=\\s|^)grimpé(?=\\s|$|[.,;:!?])", "flags": "gi", "replacement": "grimpé", "comment": "Garantit l'accent" },
        { "pattern": "\\bgrimper\\b", "flags": "gi", "replacement": "grimper" },
        { "pattern": "\\bvingt-onze\\b", "flags": "gi", "replacement": "vingt onze", "comment": "Sans tiret pour Fish" },
        { "pattern": "\\bP\\.P\\.I\\.", "flags": "g", "replacement": "pé-pé-i" },
        { "pattern": "\\bPPI\\b", "flags": "g", "replacement": "pé-pé-i" },
        { "pattern": "\\bstablecoins\\b", "flags": "gi", "replacement": "stébeul-connes", "comment": "Sinon Fish lit stèïble-côwine" },
        { "pattern": "\\bstablecoin\\b", "flags": "gi", "replacement": "stébeul-conne" }
      ]
    },
    {
      "id": "geography",
      "description": "Harmonisation orthographique + phonétique géographique. Hormuz→Ormuz harmonise l'ortho FR, puis Ormuz→hormouse phonétise pour Fish (h initial = h aspiré, empêche la liaison 'dans-ormouse').",
      "rules": [
        { "pattern": "\\bd['’]Hormuz\\b", "flags": "g", "replacement": "d'Ormuz", "comment": "Forme française du détroit" },
        { "pattern": "\\bHormuz\\b", "flags": "g", "replacement": "Ormuz" },
        { "pattern": "\\bd['’]Ormuz\\b", "flags": "gi", "replacement": "de hormouse", "comment": "Élision retirée + h aspiré → Fish dit 'de hormouse' sans liaison" },
        { "pattern": "\\bOrmuz\\b", "flags": "gi", "replacement": "hormouse", "comment": "h initial = h aspiré → empêche liaison 'dans-ormouse'" }
      ]
    },
    {
      "id": "companies_named",
      "description": "Noms de sociétés instables que Fish prononce mal en raw.",
      "rules": [
        { "pattern": "\\bTesla\\b", "flags": "gi", "replacement": "Tessla" },
        { "pattern": "\\bASML\\b", "flags": "gi", "replacement": "A.S.M.L." },
        { "pattern": "\\bMusk\\b", "flags": "gi", "replacement": "Meusk" },
        { "pattern": "\\bMousk\\b", "flags": "gi", "replacement": "Meusk" },
        { "pattern": "\\bON Semiconductor\\b", "flags": "gi", "replacement": "Onne Semi-conducteur" },
        { "pattern": "\\bNvidia\\b", "flags": "gi", "replacement": "Ènvidia" },
        { "pattern": "\\bCoinbase\\b", "flags": "gi", "replacement": "connebèse" },
        { "pattern": "\\bBlackRock\\b", "flags": "gi", "replacement": "Blakroke" },
        { "pattern": "\\bJPMorgan\\b", "flags": "gi", "replacement": "Djéï-Pi Morganne" },
        { "pattern": "\\bMicron\\b", "flags": "gi", "replacement": "Maïkronne" },
        { "pattern": "\\bTeradyne\\b", "flags": "gi", "replacement": "Téradaïne" },
        { "pattern": "\\bBroadcom\\b", "flags": "gi", "replacement": "Brodcome" },
        { "pattern": "\\bCoreWeave\\b", "flags": "gi", "replacement": "Core-ouive" },
        { "pattern": "\\bServiceNow\\b", "flags": "gi", "replacement": "Seurvissnao" },
        { "pattern": "\\bMicroStrategy\\b", "flags": "gi", "replacement": "Maïkro-stratédji" },
        { "pattern": "\\bFastenal\\b", "flags": "gi", "replacement": "Fasstenol" },
        { "pattern": "\\bHelloFresh\\b", "flags": "gi", "replacement": "Hélo-frèche" },
        { "pattern": "\\bDelivery Hero\\b", "flags": "gi", "replacement": "Déliveri Hiéro" },
        { "pattern": "\\bGoldman Sachs\\b", "flags": "gi", "replacement": "Goldmane Sax" },
        { "pattern": "\\bWells Fargo\\b", "flags": "gi", "replacement": "Ouèlse Fargo" },
        { "pattern": "\\bCitigroup\\b", "flags": "gi", "replacement": "Citigroupe" },
        { "pattern": "\\bSoftBank\\b", "flags": "gi", "replacement": "Softe-banque" },
        { "pattern": "\\bTokyo Electron\\b", "flags": "gi", "replacement": "Tokyo Élèctrone" },
        { "pattern": "\\bUnited Parcel Service\\b", "flags": "gi", "replacement": "you-naïted parssèl seurvisse" },
        { "pattern": "\\bUPS\\b", "flags": "g", "replacement": "you-pi-èss", "comment": "Case-sensitive: UPS pas 'ups' (verbe anglais)" },
        { "pattern": "\\bFedEx\\b", "flags": "gi", "replacement": "fèdèxe" },
        { "pattern": "\\bJ\\.?B\\.?\\s?Hunt\\b", "flags": "gi", "replacement": "Djéï-bi Heunte" },
        { "pattern": "\\bC\\.?H\\.?\\s?Robinson\\b", "flags": "gi", "replacement": "Ci-eïtch Robinsonne" },
        { "pattern": "\\bBNY Mellon\\b", "flags": "gi", "replacement": "Bi-ène-ouaï Mèlone" },
        { "pattern": "\\bMorgan Stanley\\b", "flags": "gi", "replacement": "Morgane Stanlé" },
        { "pattern": "\\bBank of America\\b", "flags": "gi", "replacement": "Banque of América" },
        { "pattern": "\\bCharles Schwab\\b", "flags": "gi", "replacement": "Charlse Chouab" },
        { "pattern": "\\bDeutsche\\b", "flags": "gi", "replacement": "Doïtche" },
        { "pattern": "\\bBofA\\b", "flags": "g", "replacement": "Banque of América", "comment": "Filet de sécurité abréviation — sensible à la casse pour ne pas matcher 'bofa' rare" },
        { "pattern": "\\bGS\\b", "flags": "g", "replacement": "Goldmane Sax", "comment": "Sensible à la casse: 'gs' minuscule possible dans 'logistique'" },
        { "pattern": "\\bMS\\b(?!\\.)(?!CI)", "flags": "g", "replacement": "Morgane Stanlé", "comment": "MS mais pas MSCI — sensible casse" },
        { "pattern": "\\bTSMC\\b", "flags": "gi", "replacement": "Ti-èss-èmm-ci" },
        { "pattern": "\\bAMD\\b", "flags": "g", "replacement": "A.M.D.", "comment": "Sensible casse pour éviter 'amd' faux positif" },
        { "pattern": "\\bClarity Act\\b", "flags": "gi", "replacement": "Klariti Acte", "comment": "Projet de loi US — Fish hésite entre prononciations EN/FR. Phonétique FR stable." },
        { "pattern": "\\bHSBC\\b", "flags": "g", "replacement": "achesse-bécé", "comment": "Sigle épelé FR (H-S-B-C). Tirets collent les syllabes pour Fish — sinon il lit 'ci' comme un mot." }
      ]
    },
    {
      "id": "anglicisms",
      "description": "Anglicismes finance/marché que Fish prononce mal en raw. Opus doit normalement les éviter, ces règles sont un filet.",
      "rules": [
        { "pattern": "(?<=\\s|^)pricé(?=\\s|$|[.,;:!?])", "flags": "gi", "replacement": "praïcé" },
        { "pattern": "(?<=\\s|^)pricait(?=\\s|$|[.,;:!?])", "flags": "gi", "replacement": "praïçait" },
        { "pattern": "(?<=\\s|^)pricent(?=\\s|$|[.,;:!?])", "flags": "gi", "replacement": "praïcent" },
        { "pattern": "\\bpricer\\b", "flags": "gi", "replacement": "praille-cé" },
        { "pattern": "\\bpricing\\b", "flags": "gi", "replacement": "praille-cingue" },
        { "pattern": "\\bprice\\b", "flags": "gi", "replacement": "praïce" },
        { "pattern": "\\bbull run\\b", "flags": "gi", "replacement": "boull reune" },
        { "pattern": "\\bbullish\\b", "flags": "gi", "replacement": "boulliche" },
        { "pattern": "\\bbearish\\b", "flags": "gi", "replacement": "bèriche" },
        { "pattern": "\\btankers\\b", "flags": "gi", "replacement": "tankeurs" },
        { "pattern": "\\btanker\\b", "flags": "gi", "replacement": "tankeur" }
      ]
    },
    {
      "id": "suffixes",
      "description": "Suffixes anglais courants → français (couvre des centaines de sociétés via leur nom).",
      "rules": [
        { "pattern": "\\bSemiconductor\\b", "flags": "gi", "replacement": "Semi-conducteur" },
        { "pattern": "\\bTechnologies\\b", "flags": "gi", "replacement": "Tèknolodji" },
        { "pattern": "\\bHoldings\\b", "flags": "gi", "replacement": "Holdingz" },
        { "pattern": "\\bCorporation\\b", "flags": "gi", "replacement": "Corporation" },
        { "pattern": "\\bTherapeutics\\b", "flags": "gi", "replacement": "Térapeutiks" },
        { "pattern": "\\bPartners\\b", "flags": "gi", "replacement": "Parteneurse" }
      ]
    },
    {
      "id": "indices",
      "description": "Indices boursiers (composés en premier pour matcher avant le sigle seul).",
      "rules": [
        { "pattern": "\\bS&P 500\\b", "flags": "gi", "replacement": "essenne pi cinq cents" },
        { "pattern": "\\bS\\. and P\\.", "flags": "g", "replacement": "essenne pi" },
        { "pattern": "\\bS&P\\b", "flags": "gi", "replacement": "essenne pi" },
        { "pattern": "\\bCAC 40\\b", "flags": "gi", "replacement": "caque karante" },
        { "pattern": "\\bC\\.A\\.C\\.", "flags": "g", "replacement": "caque" },
        { "pattern": "\\bCAC\\b", "flags": "g", "replacement": "caque" },
        { "pattern": "\\bDAX\\b", "flags": "gi", "replacement": "daxe" },
        { "pattern": "\\bD\\.A\\.X\\.", "flags": "g", "replacement": "daxe" },
        { "pattern": "\\bFTSE\\b", "flags": "gi", "replacement": "fouttsi" },
        { "pattern": "\\bF\\.T\\.S\\.E\\.", "flags": "g", "replacement": "fouttsi" },
        { "pattern": "\\bKOSPI\\b", "flags": "gi", "replacement": "kospi" },
        { "pattern": "\\bNasdaq\\b", "flags": "gi", "replacement": "nazdak" },
        { "pattern": "\\bDow Jones\\b", "flags": "gi", "replacement": "daou djonnze" },
        { "pattern": "\\bNikkei\\b", "flags": "gi", "replacement": "nikèï" },
        { "pattern": "\\bVIX\\b", "flags": "gi", "replacement": "vixe" },
        { "pattern": "\\bV\\.I\\.X\\.", "flags": "g", "replacement": "vixe" },
        { "pattern": "\\bRussell 2000\\b", "flags": "gi", "replacement": "reussèl deux mille" },
        { "pattern": "\\bMSCI\\b", "flags": "gi", "replacement": "èmm-èss-ci-aï" },
        { "pattern": "\\bM\\.S\\.C\\.I\\.", "flags": "g", "replacement": "èmm-èss-ci-aï" }
      ]
    },
    {
      "id": "acronyms",
      "description": "Sigles épelés (RSI, CPI, ETF...). On force la prononciation lettre par lettre.",
      "rules": [
        { "pattern": "\\bW\\.T\\.I\\.\\b", "flags": "g", "replacement": "doublevé té i" },
        { "pattern": "\\bW\\.T\\.I\\.", "flags": "g", "replacement": "doublevé té i" },
        { "pattern": "\\bWTI\\b", "flags": "g", "replacement": "doublevé té i" },
        { "pattern": "\\bDXY\\b", "flags": "g", "replacement": "D.X.Y." },
        { "pattern": "\\bRSI\\b", "flags": "g", "replacement": "R.S.I." },
        { "pattern": "\\bCOT\\b", "flags": "g", "replacement": "C.O.T." },
        { "pattern": "\\bSMA200\\b", "flags": "g", "replacement": "S.M.A. deux cents" },
        { "pattern": "\\bSMA50\\b", "flags": "g", "replacement": "S.M.A. cinquante" },
        { "pattern": "\\bSMA20\\b", "flags": "g", "replacement": "S.M.A. vingt" },
        { "pattern": "\\bEMA\\b", "flags": "g", "replacement": "E.M.A." },
        { "pattern": "\\bCPI\\b", "flags": "g", "replacement": "C.P.I." },
        { "pattern": "\\bPMI\\b", "flags": "g", "replacement": "P.M.I." },
        { "pattern": "\\bUSDC\\b", "flags": "g", "replacement": "U.S.D.C." },
        { "pattern": "\\bUSDT\\b", "flags": "g", "replacement": "U.S.D.T." },
        { "pattern": "\\bAUD\\b", "flags": "g", "replacement": "A.U.D." },
        { "pattern": "\\bE\\.T\\.F\\.", "flags": "g", "replacement": "eutéèf" },
        { "pattern": "\\bÉ\\.T\\.F\\.", "flags": "g", "replacement": "eutéèf" },
        { "pattern": "\\bETF\\b", "flags": "g", "replacement": "eutéèf" }
      ]
    },
    {
      "id": "central_banks",
      "description": "Banques centrales — prononciation française.",
      "rules": [
        { "pattern": "\\bFed\\b", "flags": "g", "replacement": "Fède" },
        { "pattern": "\\bBoJ\\b", "flags": "gi", "replacement": "Boge" },
        { "pattern": "\\bBCE\\b", "flags": "g", "replacement": "B.C.E." },
        { "pattern": "\\bBoE\\b", "flags": "g", "replacement": "bi-eau-i" },
        { "pattern": "\\bPBoC\\b", "flags": "g", "replacement": "pi-bi-eau-ci" }
      ]
    },
    {
      "id": "linguistic",
      "description": "Corrections linguistiques pures (français oral).",
      "rules": [
        { "pattern": "\\bquarante\\b", "flags": "g", "replacement": "karante" },
        { "pattern": "\\byens\\b", "flags": "gi", "replacement": "yen", "comment": "Yen invariable en français oral — Fish lit le 's' final sinon" }
      ]
    },
    {
      "id": "acronym_protections",
      "description": "Filet de sécurité — collapse les expansions étymologiques verbeuses qu'Opus pourrait inventer malgré le prompt (CAC ≠ Cotation Assistée en Continu, RSI ≠ Relative Strength Index, etc.). Appliqué EN DERNIER pour rattraper tout ce qui passe à travers les name rules de company-profiles.json.",
      "rules": [
        { "pattern": "\\bCotation Assistée en Continu (?:quarante|karante)\\b", "flags": "gi", "replacement": "caque karante" },
        { "pattern": "\\bCotation Assistée en Continu\\b", "flags": "gi", "replacement": "caque" },
        { "pattern": "\\bRelative Strength Index\\b", "flags": "gi", "replacement": "èr ès i" },
        { "pattern": "\\bVolatility Index\\b", "flags": "gi", "replacement": "vixe" },
        { "pattern": "\\bWest Texas Intermediate\\b", "flags": "gi", "replacement": "brut américain" },
        { "pattern": "\\bDeutscher Aktienindex\\b", "flags": "gi", "replacement": "daxe" },
        { "pattern": "\\bFinancial Times Stock Exchange\\b", "flags": "gi", "replacement": "fouttsi" },
        { "pattern": "\\bDow Jones Industrial Average\\b", "flags": "gi", "replacement": "daou djonnze" },
        { "pattern": "\\bStandard and Poor'?s\\b", "flags": "gi", "replacement": "essenne pi" }
      ]
    }
  ]
}
